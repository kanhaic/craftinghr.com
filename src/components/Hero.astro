---
const { titleLead, titleAccent, titleTail, subtitle, ctaText } = Astro.props as {
  titleLead: string;
  titleAccent: string;
  titleTail: string;
  subtitle: string;
  ctaText: string;
};
---

<section class="relative overflow-hidden border-b border-ink/10">
  <!-- Ruled column guides -->
  <div class="pointer-events-none absolute inset-0 mx-auto max-w-6xl px-5 sm:px-8" aria-hidden="true">
    <div class="relative h-full">
      <div class="absolute inset-y-0 left-0 w-px bg-ink/5"></div>
      <div class="absolute inset-y-0 left-1/3 hidden w-px bg-ink/5 lg:block"></div>
      <div class="absolute inset-y-0 left-2/3 hidden w-px bg-ink/5 lg:block"></div>
      <div class="absolute inset-y-0 right-0 w-px bg-ink/5"></div>
    </div>
  </div>

  <!-- Rotating stamp -->
  <div class="rise rise-4 absolute right-10 top-16 hidden lg:block xl:right-24" aria-hidden="true">
    <svg viewBox="0 0 120 120" class="h-36 w-36 animate-spin-slow">
      <defs>
        <path id="badge-circle" d="M60,60 m-46,0 a46,46 0 1,1 92,0 a46,46 0 1,1 -92,0"></path>
      </defs>
      <text class="fill-ink/50 font-mono text-[7.5px] uppercase" style="letter-spacing: 0.2em">
        <textPath href="#badge-circle">HR Software · Sales Software · Made in Mumbai ·</textPath>
      </text>
      <text x="60" y="72" text-anchor="middle" class="fill-clay font-display text-[36px]">✳</text>
    </svg>
  </div>

  <div class="relative mx-auto max-w-6xl px-5 pb-20 pt-16 sm:px-8 sm:pb-28 sm:pt-24 lg:pt-28">
    <h1
      class="rise rise-1 max-w-4xl font-display text-5xl font-medium leading-[1.02] tracking-tight sm:text-7xl lg:text-[5.5rem]"
    >
      {titleLead}
      <em class="text-clay">{titleAccent}</em>
      {titleTail}
    </h1>

    <p class="rise rise-2 mt-8 max-w-xl text-lg leading-relaxed text-ink-soft sm:text-xl">
      {subtitle}
    </p>

    <div class="rise rise-3 mt-12 flex flex-wrap items-center gap-6">
      <a
        href="#products"
        class="group inline-flex items-center gap-3 bg-ink px-7 py-4 font-mono text-xs uppercase tracking-[0.18em] text-paper transition-colors duration-200 hover:bg-clay"
      >
        {ctaText}
        <span class="transition-transform duration-200 group-hover:translate-y-0.5">↓</span>
      </a>
      <a
        href="mailto:info@craftinghr.com"
        class="group font-mono text-xs uppercase tracking-[0.18em] text-ink underline decoration-ink/30 underline-offset-8 transition-colors duration-200 hover:text-clay hover:decoration-clay"
      >
        Talk to us
        <span
          class="inline-block transition-transform duration-200 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
          >↗</span
        >
      </a>
    </div>
  </div>
</section>
